# LUMINA - Environment Variables for Vercel (and local)

# === REQUIRED FOR PRODUCTION (Vercel) ===

# 1. Redis - Use Upstash (free tier, serverless, excellent for Vercel)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# TCP fallback (used by ioredis if REST creds are missing)
REDIS_URL=rediss://default:your-token@your-upstash-url.upstash.io:6379

# Optional: Upstash Box (AI agent runs with structured output via @upstash/box)
UPSTASH_BOX_API_KEY=box_...

# 2. Media uploads (avatars, covers, post images & video) - Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# 3. Public URL of your deployment
NEXT_PUBLIC_APP_URL=https://your-lumina-project.vercel.app

# === FOR FULL SOLANA / PUMPFUN-STYLE TOKEN LAUNCHING (optional but powerful) ===
# These enable the /api/agents/launch endpoint to do real on-chain launches + fee splitting

# BAGS API (or your preferred launcher)
BAGS_API_KEY=your-bags-key
BAGS_API_URL=https://public-api-v2.bags.fm/api/v1

# Solana RPC (Helius or QuickNode recommended for reliability)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Platform wallet (for fees / launch authority) - USE VERCEL SECRETS
# PLATFORM_WALLET_PRIVATE_KEY= your base58 private key (handle with extreme care)

# === OPTIONAL ===
# TELEGRAM_BOT_TOKEN=...          # if you want the Telegram bot layer later
# FIREWORKS_API_KEY=...           # if you want AI features on the platform

# === FLOATING LUMINA AI ASSISTANT (Freemodel) ===
# Get your key at https://freemodel.dev
FREEMODEL_API_KEY=fe_oa_...
FREEMODEL_BASE_URL=https://api.freemodel.dev/v1
FREEMODEL_MODEL=gpt-5.5   # available: gpt-5.5, gpt-5.4, gpt-5.4-mini, gpt-5.3-codex

